    (2) bloc -> bloc . statement SEMI
    (4) statement -> . PRINT LPAREN expression RPAREN
    (5) statement -> . NAME EGAL expression
    (17) statement -> . IF LPAREN expression RPAREN LACC bloc RACC
    (18) statement -> . IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC
    (19) statement -> . WHILE LPAREN expression RPAREN LACC bloc RACC
    (22) statement -> . FOR LPAREN statement SEMI expression SEMI statement RPAREN LACC bloc RACC
    (23) statement -> . DEF NAME LPAREN param_list RPAREN LACC bloc RACC
    (27) statement -> . RETURN expression
    (35) statement -> . EXEC LPAREN expression RPAREN

    RACC            shift and go to state 97
    PRINT           shift and go to state 4
    NAME            shift and go to state 5
    IF              shift and go to state 6
    WHILE           shift and go to state 7
    FOR             shift and go to state 8
    DEF             shift and go to state 9
    RETURN          shift and go to state 10
    EXEC            shift and go to state 11

    statement                      shift and go to state 12

state 96

    (18) statement -> IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC .

    SEMI            reduce using rule 18 (statement -> IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC .)
    RPAREN          reduce using rule 18 (statement -> IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC .)


state 97

    (22) statement -> FOR LPAREN statement SEMI expression SEMI statement RPAREN LACC bloc RACC .

    SEMI            reduce using rule 22 (statement -> FOR LPAREN statement SEMI expression SEMI statement RPAREN LACC bloc RACC .)
    RPAREN          reduce using rule 22 (statement -> FOR LPAREN statement SEMI expression SEMI statement RPAREN LACC bloc RACC .)

