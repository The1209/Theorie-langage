Grammar

Rule 0     S' -> start
Rule 1     start -> bloc
Rule 2     bloc -> bloc statement SEMI
Rule 3     bloc -> statement SEMI
Rule 4     statement -> PRINT LPAREN expression RPAREN
Rule 5     statement -> NAME EGAL expression
Rule 6     expression -> expression SUP expression
Rule 7     expression -> expression INF expression
Rule 8     expression -> expression INFEG expression
Rule 9     expression -> expression EGALEGAL expression
Rule 10    expression -> expression AND expression
Rule 11    expression -> expression OR expression
Rule 12    expression -> expression PLUS expression
Rule 13    expression -> expression TIMES expression
Rule 14    expression -> LPAREN expression RPAREN
Rule 15    expression -> NUMBER
Rule 16    expression -> NAME
Rule 17    statement -> IF LPAREN expression RPAREN LACC bloc RACC
Rule 18    statement -> IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC
Rule 19    statement -> WHILE LPAREN expression RPAREN LACC bloc RACC
Rule 20    expression -> expression MINUS expression
Rule 21    expression -> expression DIVIDE expression
Rule 22    statement -> FOR LPAREN statement SEMI expression SEMI statement RPAREN LACC bloc RACC
Rule 23    statement -> DEF NAME LPAREN param_list RPAREN LACC bloc RACC
Rule 24    param_list -> param_list COMMA NAME
Rule 25    param_list -> NAME
Rule 26    param_list -> empty
Rule 27    statement -> RETURN expression
Rule 28    expression -> NAME LPAREN arg_list RPAREN
Rule 29    arg_list -> arg_list COMMA expression
Rule 30    arg_list -> expression
Rule 31    arg_list -> empty
Rule 32    empty -> <empty>
Rule 33    expression -> EVAL LPAREN expression RPAREN
Rule 34    expression -> STRING
Rule 35    statement -> EXEC LPAREN expression RPAREN

